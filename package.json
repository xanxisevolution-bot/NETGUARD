{
  "name": "netguard-monitor",
  "version": "2.2.0",
  "description": "NetGuard - Internet Monitor Dashboard with Real Diagnostics",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.netguard.monitor",
    "productName": "NetGuard Monitor",
    "win": {
      "icon": "icon.ico",
      "target": ["portable"]
    },
    "files": [
      "main.js",
      "server.js",
      "dashboard.html",
      "tray-icon.png",
      "icon.png",
      "icon.ico"
    ],
    "portable": {
      "artifactName": "NetGuard-Monitor.exe"
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
